APP_NAME=TIF Normas Assistant API
APP_ENV=dev
APP_VERSION=1.0.0
APP_LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

POSTGRES_DB=tif_normas
POSTGRES_USER=tif
POSTGRES_PASSWORD=tif_password

DATABASE_URL=postgresql+psycopg://tif:tif_password@db:5432/tif_normas
DB_ECHO=false
LEGACY_SQLITE_PATH=data/normas.db

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60

RETRIEVAL_TOP_K_DEFAULT=8
RETRIEVAL_TOP_K_MAX=20
RETRIEVAL_CANDIDATE_POOL=200
RETRIEVAL_SNIPPET_CHARS=2000

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

